# 로컬 테스트용 (GitHub에는 Secrets and variables → Actions에 등록)
SKIP_SSL_VERIFY=1
DRY_RUN=1
PUBLISH_ONLY=0
POST_LIMIT=2
# LOG_DATE=2026-06-18

# 1=키워드 수집 실패(시드만) 시에도 강제 진행 / 0=중단 (기본)
ALLOW_SEED_FALLBACK=0

GEMINI_API_KEY=
# gemini-2.5-flash 무료: 모델당 일 20회(RPD) — 테스트·재실행 주의
GEMINI_MODEL=gemini-2.5-flash
GEMINI_DELAY_SECONDS=45
GEMINI_TIMEOUT_SECONDS=180
GEMINI_QUOTA_RETRIES=3

# SerpApi — Google Trends 급상승 (https://serpapi.com)
SERPAPI_KEY=
SERPAPI_GEO=KR
SERPAPI_ONLY_ACTIVE=1
SERPAPI_HOURS=24
# 0=SerpApi만 사용(실패·부족 시 중단) / 1=자동완성·pytrends fallback
SERPAPI_FALLBACK=0

# 티스토리 자동 게시 (내부 API + 로그인 쿠키)
TISTORY_BLOG=happy-life-smile
TISTORY_CATEGORY_ID=0
TISTORY_COOKIE=

POST_DELAY_SECONDS=120
PUBLISH_RETRIES=3

# 출처 URL live 검증 (1=HEAD/GET 확인, 0=도메인 화이트리스트만 — 기본 권장)
VALIDATE_SOURCE_URLS=0
SOURCE_URL_TIMEOUT_SECONDS=8

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
